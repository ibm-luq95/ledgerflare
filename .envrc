export DJANGO_SUPERUSER_USER_TYPE=manager
export DJANGO_SUPERUSER_USER_GENRE=developer
export PYTHONDONTWRITEBYTECODE=1
export UV_LINK_MODE=symlink

# ——— project aliases as scripts ———
export_alias rm_node_modules 'rm -rfv node_modules/.cache; rm -rfv node_modules; rm -rfv build; rm -v package-lock.json; rm -v pnpm-lock.yaml'

export_alias run_docformatter '/home/ibrahim-pc/.virtualenvs/Leadger_Flear_Venv3.13/bin/docformatter --config "/run/media/ibrahim-pc/Primary/P_IBM/MY_Projects/Freelancing/Albert_Salazar/Beach_Wood_Financial/pyproject.toml"'
