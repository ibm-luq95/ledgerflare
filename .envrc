# ——— alias helper ———
export_alias() {
  local name="$1"
  shift
  local alias_dir="$PWD/.direnv/aliases"
  local target="$alias_dir/$name"

  mkdir -p "$alias_dir"

  # Add alias_dir to PATH if not already present
  if [[ ":$PATH:" != *":$alias_dir:"* ]]; then
    PATH_add "$alias_dir"
  fi

  cat > "$target" <<EOF
#!/usr/bin/env bash
$@
EOF

  chmod +x "$target"
}

# ——— environment setup ———
layout virtualenvwrapper Leadger_Flear_Venv3.13

export NODE_ENV=development
export XUSER=ibrahim-pc
export XHOME=/home/${XUSER}
export DJANGO_SUPERUSER_PASSWORD=test123456
