{
  "name": "python-webpack-boilerplate",
  "version": "1.0.1",
  "description": "Webpack boilerplate for Django & Flask",
  "scripts": {
    "build": "cross-env NODE_ENV=production webpack --config webpack/webpack.config.prod.js",
    "start": "webpack serve --config webpack/webpack.config.dev.js",
    "watch": "cross-env NODE_ENV=dev webpack --watch --config webpack/webpack.config.watch.cjs",
    "tailwindcss": "tailwindcss -i ./src/styles/index.scss -o ./build/css/app.css --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AccordBox/python-webpack-boilerplate"
  },
  "keywords": [
    "webpack",
    "startkit",
    "frontend"
