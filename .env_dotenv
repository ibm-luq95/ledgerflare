export NODE_ENV=development
export XUSER=ibrahim-pc
export XHOME=/home/${XUSER}
export DJANGO_SUPERUSER_PASSWORD=test123456
export DJANGO_SUPERUSER_EMAIL=admin@admin.com
export DJANGO_SUPERUSER_USER_TYPE=manager
export DJANGO_SUPERUSER_USER_GENRE=developer
export PYTHONDONTWRITEBYTECODE=1
#conda activate beachwood_financial_venv_3.12
#workon beachwood_financial_venv_3.13
# Check if the activate script exists and source it if it does
if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
elif [ -f ".venv/Scripts/activate" ]; then
    source .venv/Scripts/activate
else
    echo "Warning: Virtual environment not found. Please check the path to your virtual environment's activate script."
fi

# Define the alias
alias rm_node_modules='rm -rfv node_modules; rm -rfv build; rm -v package-lock.json; rm -v pnpm-lock.yaml'

